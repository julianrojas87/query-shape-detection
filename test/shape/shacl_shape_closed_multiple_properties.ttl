@prefix sh:   <http://www.w3.org/ns/shacl#> .
@prefix foaf: <http://foaf.example/#> .
@prefix ex:   <http://ex.example/#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

<http:exemple.ca/foo> a sh:NodeShape ;
    sh:closed true ;
    sh:property [ sh:path ex:state ] ;
    sh:property [ sh:path foaf:name ] ;
    sh:property [ sh:path foaf:mbox ] ;
    sh:property [ sh:path foaf:hunter ] ;
    sh:property [ sh:path foaf:me ] .
